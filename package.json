{
  "name": "chordshark",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "husky": "^3.0.0",
    "lint-staged": "^9.2.0",
    "react-test-renderer": "^16.8.6",
    "redux-mock-store": "^1.5.4"
  },
  "dependencies": {
    "@tonaljs/modules": "^3.4.2",
    "@tonaljs/range": "^3.2.4",
    "classnames": "^2.2.6",
    "dotenv": "^7.0.0",
    "envalid": "^4.2.2",
    "node-sass": "^7.0.0",
    "ramda": "^0.26.1",
    "react": "^16.13.0",
    "react-dom": "^16.13.0",
    "react-redux": "^7.2.0",
    "react-router-dom": "^5.1.2",
    "react-scripts": "3.4.0",
    "redux": "^4.0.5",
    "redux-logger": "^3.0.6",
    "webmidi": "^2.3.2"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "jest --bail --findRelatedTests"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --single-quote --write",
      "git add"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "engines": {
    "node": "12.x",
    "yarn": "1.12.1"
  }
}
